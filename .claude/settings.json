{
  "permissions": {
    "allow": [
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm test)",
      "Bash(pnpm build *)",
      "Bash(uv run python3 scripts/agent-guards/skill_runtime_exec.py --command-id preflight.run --issue-number * --repo squne121/loop-protocol)",
      "Bash(uv run python3 scripts/agent-guards/skill_runtime_exec.py --command-id preflight.run.with_anchor --issue-number * --repo squne121/loop-protocol --anchor-comment-url *)",
      "Bash(uv run --locked python3 .claude/skills/edit-issue/scripts/*.py *)",
      "Bash(uv run --locked python3 .claude/skills/post-merge-cleanup/scripts/*.py *)",
      "Bash(uv run --locked python3 .claude/skills/create-issue/scripts/*.py *)",
      "Bash(uv run python3 scripts/agent-guards/controlled_skill_mutation_exec.py *)",
      "Bash(.claude/skills/create-issue/scripts/*.sh *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git log *)",
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(git worktree *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(gh issue edit *)",
      "Bash(gh issue create *)",
      "Bash(gh issue close *)",
      "Bash(gh issue comment *)",
      "Bash(gh issue view *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr create *)",
      "Bash(gh pr review *)",
      "Bash(gh pr comment *)",
      "Bash(gh pr view *)",
      "Bash(gh api *)"
    ],
    "ask": [],
    "deny": [
      "mcp__context-mode__ctx_execute",
      "mcp__context-mode__ctx_batch_execute",
      "mcp__context-mode__ctx_execute_file",
      "mcp__context-mode__ctx_fetch_and_index",
      "Edit(assets/**)",
      "Edit(LICENSES/**)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(secrets/**)",
      "Read(./secrets/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(secrets/**)",
      "Read(**/.netrc)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Read(**/credentials)",
      "Read(**/settings.local.json)",
      "Read(**/.ssh/**)",
      "Read(**/.config/gh/**)",
      "Read(**/.claude/**)",
      "Edit(**/.ssh/**)",
      "Edit(**/.config/gh/**)",
      "Bash(gh secret *)",
      "Bash(printenv *)",
      "Bash(printenv)",
      "Bash(export -p)",
      "Bash(* .env*)",
      "Bash(env)",
      "Bash(env *)",
      "Bash(set)",
      "Bash(set *)"
    ]
  },
  "enabledPlugins": {
    "context-mode@context-mode": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit|Grep|Glob|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/secret_boundary_guard.sh",
            "args": [],
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/local_main_branch_guard.sh",
            "args": [],
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/worktree_scope_guard.sh",
            "args": [],
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-japanese-prose.sh",
            "args": [],
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/rtk_boundary_shadow_guard.sh",
            "args": [],
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/ci_test_performance_advisory.sh",
            "args": [],
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/root_temporary_residue_advisory.sh",
            "args": [],
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session_manifest_coordinator.sh",
            "args": [],
            "timeout": 55
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session_manifest_coordinator.sh",
            "args": [],
            "timeout": 55
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/session_manifest_debounce.mjs"
            ],
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/save_loop_state_before_compaction.sh",
            "args": [],
            "timeout": 30
          }
        ]
      }
    ]
  }
}
