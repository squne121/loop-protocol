{
  "permissions": {
    "allow": [
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm test)",
      "Bash(pnpm build *)",
      "Bash(uv run python3 .claude/skills/edit-issue/scripts/*.py *)",
      "Bash(uv run python3 .claude/skills/post-merge-cleanup/scripts/*.py *)",
      "Bash(uv run python3 .claude/skills/create-issue/scripts/*.py *)",
      "Bash(.claude/skills/create-issue/scripts/*.sh *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git log *)",
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(git worktree *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(gh issue edit *)",
      "Bash(gh issue create *)",
      "Bash(gh issue close *)",
      "Bash(gh issue comment *)",
      "Bash(gh issue view *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr create *)",
      "Bash(gh pr review *)",
      "Bash(gh pr comment *)",
      "Bash(gh pr view *)",
      "Bash(gh api *)"
    ],
    "ask": [],
    "deny": [
      "Write(assets/**)",
      "Edit(assets/**)",
      "Write(LICENSES/**)",
      "Edit(LICENSES/**)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session_recording_policy_guard.sh",
            "args": [],
            "timeout": 120
          },
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/generate_session_manifest_from_hook.mjs"],
            "timeout": 60
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session_recording_policy_guard.sh",
            "args": [],
            "timeout": 120
          },
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/generate_session_manifest_from_hook.mjs"],
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/generate_session_manifest_from_hook.mjs"],
            "timeout": 60
          }
        ]
      }
    ]
  }
}
