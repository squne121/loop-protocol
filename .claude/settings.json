{
  "permissions": {
    "allow": [
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm test)",
      "Bash(pnpm build *)",
      "Bash(uv run python3 .claude/skills/edit-issue/scripts/*.py *)",
      "Bash(uv run python3 .claude/skills/post-merge-cleanup/scripts/*.py *)",
      "Bash(uv run python3 .claude/skills/create-issue/scripts/*.py *)",
      "Bash(.claude/skills/create-issue/scripts/*.sh *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git log *)",
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(git worktree *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(gh issue edit *)",
      "Bash(gh issue create *)",
      "Bash(gh issue close *)",
      "Bash(gh issue comment *)",
      "Bash(gh issue view *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr create *)",
      "Bash(gh pr review *)",
      "Bash(gh pr comment *)",
      "Bash(gh pr view *)",
      "Bash(gh api *)"
    ],
    "ask": [],
    "deny": [
      "Write(assets/**)",
      "Edit(assets/**)",
      "Write(LICENSES/**)",
      "Edit(LICENSES/**)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(secrets/**)",
      "Read(./secrets/**)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(secrets/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(secrets/**)",
      "Read(**/.netrc)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Read(**/credentials)",
      "Read(**/settings.local.json)",
      "Bash(gh secret *)",
      "Bash(printenv *)",
      "Bash(printenv)",
      "Bash(export -p)",
      "Bash(* .env*)",
      "Bash(env)",
      "Bash(env *)",
      "Bash(set)",
      "Bash(set *)",
      "mcp__context-mode-experiment__ctx_execute",
      "mcp__context-mode-experiment__ctx_fetch_and_index"
    ]
  },
  "mcpServers": {
    "context-mode-experiment": {
      "_comment": "context-mode MCP server - 実験用 profile 限定。ctx_execute / ctx_fetch_and_index は deny policy で禁止。",
      "_scope": "experiment",
      "_profile": "experiment",
      "_install_note": "npm install -g context-mode でインストール後に有効化する。現時点では未インストール（#824 実装段階）。",
      "_permission_policy": {
        "ctx_execute": "deny",
        "ctx_fetch_and_index": "deny",
        "ctx_batch_execute": "allow-with-review",
        "ctx_execute_file": "allow-with-review",
        "ctx_index": "allow",
        "ctx_search": "allow",
        "ctx_stats": "allow",
        "ctx_doctor": "allow",
        "ctx_upgrade": "allow-with-review",
        "ctx_purge": "allow-with-review",
        "ctx_insight": "allow"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/secret_boundary_guard.sh",
            "args": [],
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-japanese-prose.sh",
            "args": [],
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session_manifest_coordinator.sh",
            "args": [],
            "timeout": 180
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session_manifest_coordinator.sh",
            "args": [],
            "timeout": 180
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/generate_session_manifest_from_hook.mjs"],
            "timeout": 60
          }
        ]
      }
    ]
  }
}
