{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CONTRACT_PATCH_PLAN_V1",
  "description": "Generation-only plan describing how an Issue contract (In Scope / Out of Scope / Acceptance Criteria / Stop Conditions / Verification Commands) should be patched from an explicit human-review directive (#1323). direct_github_write is never performed from this schema's producer -- application happens via issue-author / edit-issue skill.",
  "type": "object",
  "required": [
    "schema_version",
    "target_issue_number",
    "base_issue_body_sha256",
    "source_evidence",
    "operations",
    "forbidden",
    "required_next_step"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "CONTRACT_PATCH_PLAN_V1"
    },
    "target_issue_number": { "type": ["integer", "null"], "minimum": 1 },
    "base_issue_body_sha256": { "type": ["string", "null"] },
    "source_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_ref", "source_body_sha256", "author_association"],
        "additionalProperties": false,
        "properties": {
          "source_ref": { "type": ["string", "null"] },
          "source_body_sha256": { "type": ["string", "null"] },
          "author_association": {
            "type": ["string", "null"],
            "enum": ["OWNER", "MEMBER", "COLLABORATOR", "CONTRIBUTOR", "NONE", null]
          }
        }
      }
    },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["section", "op", "text", "rationale", "source_evidence_index"],
        "additionalProperties": false,
        "properties": {
          "section": {
            "type": "string",
            "enum": [
              "In Scope",
              "Out of Scope",
              "Acceptance Criteria",
              "Stop Conditions",
              "Verification Commands",
              "Allowed Paths"
            ]
          },
          "op": {
            "type": "string",
            "enum": ["append"]
          },
          "text": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "source_evidence_index": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "forbidden": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["direct_github_write", "implementation_phase_transition"]
      },
      "minItems": 2,
      "uniqueItems": true
    },
    "required_next_step": {
      "type": "string",
      "const": "rerun_refinement_after_contract_update"
    }
  }
}
