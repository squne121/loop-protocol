{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RefinementPreflightInput",
  "description": "Input schema for run_refinement_preflight.py (--fixture mode). Provides pre-fetched issue/comment data to bypass gh CLI calls in tests.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "issue_number", "repo", "issue"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "refinement_preflight_input/v1",
      "description": "Schema version sentinel."
    },
    "issue_number": {
      "type": "integer",
      "description": "GitHub Issue number (int-normalized)."
    },
    "repo": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$",
      "description": "owner/repo string."
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "title", "body", "labels"],
      "properties": {
        "number": {"type": "integer"},
        "title": {"type": "string"},
        "body": {"type": "string"},
        "labels": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "comments": {
      "type": "array",
      "description": "Issue comments. Each item must include id and body.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "body"],
        "properties": {
          "id": {"type": "integer"},
          "body": {"type": "string"},
          "issue_url": {"type": "string"}
        }
      }
    },
    "anchor_comments": {
      "type": "array",
      "description": "Pre-validated anchor comment objects (used in --fixture mode). issue_url is required by anchor validation runtime — absence or empty string triggers ANCHOR_NOT_IN_ISSUE blocked.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "body"],
        "properties": {
          "id": {"type": "integer"},
          "body": {"type": "string"},
          "issue_url": {"type": "string"}
        }
      }
    },
    "anchor_comment_urls": {
      "type": "array",
      "description": "Anchor comment URLs to validate structurally (used in fixture mode to trigger anchor validation with fixture data).",
      "items": {"type": "string"}
    },
    "known_context": {
      "type": ["object", "null"],
      "description": "Optional known_context forwarded to plan_refinement_loop.py.",
      "additionalProperties": true
    },
    "now": {
      "type": ["string", "null"],
      "description": "Optional ISO timestamp override for deterministic output."
    }
  }
}
