{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "loop_handoff_result_v1",
  "title": "LOOP_HANDOFF_RESULT_V1",
  "description": "Terminal output of issue-refinement-loop on approved termination. SSOT: references/termination-policy.md",
  "type": "object",
  "required": ["LOOP_HANDOFF_RESULT_V1"],
  "additionalProperties": false,
  "properties": {
    "LOOP_HANDOFF_RESULT_V1": {
      "type": "object",
      "required": [
        "status",
        "routing_action",
        "contract_review",
        "metadata",
        "auto_fixes",
        "blockers",
        "permissions",
        "generated_at",
        "checked_body_sha256",
        "checker_exit_code",
        "missing_sections",
        "missing_contract_keys"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["impl_ready", "human_judgment_required", "blocked"]
        },
        "routing_action": {
          "type": "string",
          "enum": ["run_impl_review_loop", "ask_human", "blocked"]
        },
        "contract_review": {
          "type": "object",
          "required": ["status", "gate_result", "latest_comment_url", "generated_at", "body_sha256"],
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["go", "blocked"],
              "description": "Mirrors CONTRACT_REVIEW_RESULT_V1.status. Does not collide with top-level LOOP_HANDOFF_RESULT_V1.status."
            },
            "gate_result": {
              "type": "string",
              "enum": [
                "fresh_go",
                "missing_go",
                "stale_go",
                "invalidated_by_request_changes",
                "blocked"
              ]
            },
            "latest_comment_url": {
              "type": "string"
            },
            "generated_at": {
              "type": "string",
              "format": "date-time"
            },
            "body_sha256": {
              "type": "string"
            }
          }
        },
        "metadata": {
          "type": "object",
          "required": ["title_prefix_ready", "phase_label_ready"],
          "additionalProperties": false,
          "properties": {
            "title_prefix_ready": {
              "type": "boolean"
            },
            "phase_label_ready": {
              "type": "boolean"
            }
          }
        },
        "auto_fixes": {
          "type": "object",
          "required": ["result", "required", "skipped"],
          "additionalProperties": false,
          "properties": {
            "result": {
              "type": "string",
              "enum": ["auto_fixed", "human_judgment_required", "blocked"]
            },
            "required": {
              "type": "array",
              "items": { "$ref": "#/definitions/auto_fix_item" }
            },
            "skipped": {
              "type": "array",
              "items": { "$ref": "#/definitions/auto_fix_item" }
            }
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "description"],
            "additionalProperties": false,
            "properties": {
              "kind": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "permissions": {
          "type": "object",
          "required": ["unavailable"],
          "additionalProperties": false,
          "properties": {
            "unavailable": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "checked_body_sha256": {
          "type": "string",
          "description": "チェック対象の Issue body の SHA-256 ハッシュ（sha256: プレフィックス付き）"
        },
        "checker_exit_code": {
          "type": "integer",
          "description": "チェックスクリプトの終了コード（0: pass, 1: fail）",
          "enum": [0, 1]
        },
        "missing_sections": {
          "type": "array",
          "description": "不足しているセクション名のリスト（pass 時は空）",
          "items": {"type": "string"}
        },
        "missing_contract_keys": {
          "type": "array",
          "description": "不足している contract キーのリスト（pass 時は空）",
          "items": {"type": "string"}
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "impl_ready" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "routing_action": { "const": "run_impl_review_loop" },
              "contract_review": {
                "properties": {
                  "status": { "const": "go" },
                  "gate_result": { "const": "fresh_go" }
                }
              },
              "blockers": { "maxItems": 0 },
              "permissions": {
                "properties": { "unavailable": { "maxItems": 0 } }
              },
              "auto_fixes": {
                "properties": { "skipped": { "maxItems": 0 } }
              }
            }
          }
        }
      ]
    }
  },
  "definitions": {
    "auto_fix_item": {
      "type": "object",
      "required": ["kind", "executor", "result", "evidence"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "template_hygiene",
            "metadata_hygiene",
            "known_marker_fix",
            "stale_state_label_cleanup",
            "contract_snapshot_materialization"
          ]
        },
        "executor": {
          "type": "string",
          "enum": ["implementation-worker"]
        },
        "result": {
          "type": "string",
          "enum": ["applied", "skipped", "failed"]
        },
        "evidence": {
          "type": "object",
          "required": ["before", "after", "comment_url"],
          "additionalProperties": false,
          "properties": {
            "before": { "type": "string" },
            "after": { "type": "string" },
            "comment_url": { "type": "string" }
          }
        }
      }
    }
  }
}
