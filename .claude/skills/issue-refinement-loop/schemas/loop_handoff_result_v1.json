{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "loop_handoff_result_v1",
  "title": "LOOP_HANDOFF_RESULT_V1",
  "description": "Terminal output of issue-refinement-loop on approved termination. SSOT: references/termination-policy.md",
  "type": "object",
  "required": [
    "status",
    "routing_action",
    "contract_review",
    "metadata",
    "auto_fixes",
    "blockers",
    "permissions",
    "generated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["impl_ready", "human_judgment_required", "blocked"]
    },
    "routing_action": {
      "type": "string",
      "enum": ["run_impl_review_loop", "ask_human", "blocked"]
    },
    "contract_review": {
      "type": "object",
      "required": ["status", "gate_result", "latest_comment_url", "generated_at", "body_sha256"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["go", "blocked"],
          "description": "Mirrors CONTRACT_REVIEW_RESULT_V1.status. Does not collide with top-level LOOP_HANDOFF_RESULT_V1.status."
        },
        "gate_result": {
          "type": "string",
          "enum": [
            "fresh_go",
            "missing_go",
            "stale_go",
            "invalidated_by_request_changes",
            "blocked"
          ]
        },
        "latest_comment_url": {
          "type": "string"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "body_sha256": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["title_prefix_ready", "phase_label_ready"],
      "additionalProperties": false,
      "properties": {
        "title_prefix_ready": {
          "type": "boolean"
        },
        "phase_label_ready": {
          "type": "boolean"
        }
      }
    },
    "auto_fixes": {
      "type": "object",
      "required": ["required", "skipped"],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "items": { "$ref": "#/definitions/auto_fix_item" }
        },
        "skipped": {
          "type": "array",
          "items": { "$ref": "#/definitions/auto_fix_item" }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "description"],
        "additionalProperties": false,
        "properties": {
          "kind": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "permissions": {
      "type": "object",
      "required": ["unavailable"],
      "additionalProperties": false,
      "properties": {
        "unavailable": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "auto_fix_item": {
      "type": "object",
      "required": ["kind", "executor", "result", "evidence"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "template_hygiene",
            "metadata_hygiene",
            "known_marker_fix",
            "stale_state_label_cleanup",
            "contract_snapshot_materialization"
          ]
        },
        "executor": { "type": "string" },
        "result": {
          "type": "string",
          "enum": ["applied", "skipped", "failed"]
        },
        "evidence": {
          "type": "object",
          "required": ["before", "after", "comment_url"],
          "additionalProperties": false,
          "properties": {
            "before": { "type": "string" },
            "after": { "type": "string" },
            "comment_url": { "type": "string" }
          }
        }
      }
    }
  }
}
