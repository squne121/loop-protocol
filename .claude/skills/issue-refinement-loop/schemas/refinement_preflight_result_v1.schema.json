{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RefinementPreflightResultV1",
  "description": "Output schema for run_refinement_preflight.py result artifact. Strict: additionalProperties false.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "issue_number",
    "repo",
    "planner_exit_code",
    "planner_fail_closed",
    "next_action",
    "must_read",
    "do_not_read",
    "commands",
    "blockers",
    "artifacts",
    "hashes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "refinement_preflight_result/v1",
      "description": "Schema version sentinel."
    },
    "status": {
      "type": "string",
      "enum": ["pass", "warn", "blocked", "environment_failure"],
      "description": "Wrapper-level status after applying exit_code_mapping table."
    },
    "issue_number": {
      "type": "integer",
      "description": "GitHub Issue number."
    },
    "repo": {
      "type": "string",
      "description": "owner/repo string."
    },
    "planner_exit_code": {
      "type": ["integer", "null"],
      "description": "Exit code returned by plan_refinement_loop.py. Null if planner was not invoked."
    },
    "planner_fail_closed": {
      "type": ["boolean", "null"],
      "description": "Value of plan.fail_closed.required from planner output. Null if planner was not invoked."
    },
    "next_action": {
      "type": "string",
      "description": "Suggested next action for the orchestrator (e.g. 'proceed', 'human_judgment_required', 'fix_environment')."
    },
    "must_read": {
      "type": "array",
      "description": "Files/paths the orchestrator must read before proceeding.",
      "items": {"type": "string"}
    },
    "do_not_read": {
      "type": "array",
      "description": "Files/paths the orchestrator must not read to conserve context.",
      "items": {"type": "string"}
    },
    "commands": {
      "type": "array",
      "description": "Suggested commands. Each item must use argv array only (no shell strings).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "argv", "shell", "source"],
        "properties": {
          "kind": {
            "type": "string",
            "description": "Command kind (e.g. 'run_planner', 'validate_schema')."
          },
          "argv": {
            "type": "array",
            "description": "Argument vector. Must not contain shell-interpolated strings.",
            "items": {"type": "string"}
          },
          "shell": {
            "type": "boolean",
            "const": false,
            "description": "Always false. Shell execution is prohibited."
          },
          "source": {
            "type": "string",
            "const": "static_wrapper_template",
            "description": "Origin of this command template."
          }
        }
      }
    },
    "planner_fail_closed_reason_codes": {
      "type": "array",
      "description": "Planner fail_closed reason codes mirrored for schema-safe forwarding.",
      "items": {"type": "string"}
    },
    "required_sections": {
      "type": "array",
      "description": "Sections required by FAIL_CLOSED_REWRITE_CONSTRAINTS_V1.required_sections (planner-derived).",
      "items": {"type": "string"}
    },
    "required_contract_keys": {
      "type": "array",
      "description": "Contract keys required by FAIL_CLOSED_REWRITE_CONSTRAINTS_V1.required_contract_keys (planner-derived).",
      "items": {"type": "string"}
    },
    "rewrite_constraints": {
      "type": "object",
      "description": "Planner fail_closed rewrite constraints mirrored for artifact/compact passthrough.",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "required_sections",
        "required_contract_keys",
        "rewrite_constraints",
        "override_policy",
        "max_rewrite_attempts",
        "no_progress_route"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "FAIL_CLOSED_REWRITE_CONSTRAINTS_V1"
        },
        "required_sections": {
          "type": "array",
          "items": {"type": "string"}
        },
        "required_contract_keys": {
          "type": "array",
          "items": {"type": "string"}
        },
        "rewrite_constraints": {
          "type": "object",
          "required": ["must_add_sections", "must_add_contract_keys", "freeform_rewrite_forbidden"],
          "additionalProperties": false,
          "properties": {
            "must_add_sections": {
              "type": "array",
              "items": {"type": "string"}
            },
            "must_add_contract_keys": {
              "type": "array",
              "items": {"type": "string"}
            },
            "freeform_rewrite_forbidden": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "override_policy": {
          "type": "object",
          "required": [
            "allowed_reason_codes",
            "never_override_reason_codes",
            "overridable_in_current_result",
            "non_overridable_in_current_result"
          ],
          "additionalProperties": false,
          "properties": {
            "allowed_reason_codes": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "missing_required_section",
                  "missing_required_contract_key"
                ]
              }
            },
            "never_override_reason_codes": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "unknown_issue_kind",
                  "issue_kind_policy_load_error",
                  "contract_schema_parse_error",
                  "template_resolution_error",
                  "checker_internal_error"
                ]
              }
            },
            "overridable_in_current_result": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "missing_required_section",
                  "missing_required_contract_key"
                ]
              }
            },
            "non_overridable_in_current_result": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "unknown_issue_kind",
                  "issue_kind_policy_load_error",
                  "contract_schema_parse_error",
                  "template_resolution_error",
                  "checker_internal_error",
                  "malformed_machine_readable_contract",
                  "unknown_input_schema",
                  "planner_internal_error",
                  "missing_required_parent_section",
                  "template_required_sections_unavailable"
                ]
              }
            }
          }
        },
        "max_rewrite_attempts": {
          "type": "integer"
        },
        "no_progress_route": {
          "type": "string"
        }
      }
    },
    "blockers": {
      "type": "array",
      "description": "Blocker reason codes (e.g. 'ANCHOR_NOT_IN_ISSUE').",
      "items": {"type": "string"}
    },
    "artifacts": {
      "type": "object",
      "description": "Paths to artifact files written by this wrapper.",
      "additionalProperties": false,
      "properties": {
        "raw_issue_snapshot": {"type": "string", "description": "Path to raw_issue_snapshot.json"},
        "planner_input": {"type": "string", "description": "Path to planner_input.json"},
        "refinement_preflight_result_v1": {"type": "string", "description": "Path to refinement_preflight_result_v1.json"}
      }
    },
    "hashes": {
      "type": "object",
      "description": "SHA256 hashes of key artifacts for byte-stability verification.",
      "additionalProperties": false,
      "properties": {
        "raw_issue_snapshot_sha256": {"type": "string", "description": "SHA256 of canonical JSON of raw_issue_snapshot."},
        "planner_input_sha256": {"type": "string", "description": "SHA256 of canonical JSON of planner_input."},
        "result_core_sha256": {"type": "string", "description": "SHA256 of canonical JSON of result core fields (excl. artifacts, hashes)."}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "planner_fail_closed": {"const": true}
        },
        "required": ["planner_fail_closed"]
      },
      "then": {
        "required": [
          "planner_fail_closed_reason_codes",
          "required_sections",
          "required_contract_keys",
          "rewrite_constraints"
        ]
      }
    }
  ]
}
