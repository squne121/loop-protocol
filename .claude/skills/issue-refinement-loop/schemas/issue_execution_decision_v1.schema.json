{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "issue_execution_decision/v1",
  "title": "ISSUE_EXECUTION_DECISION_V1",
  "description": "Canonical static decision shape. Semantic invariants and canonical digest verification are owned by the normative validator in Issue #1677.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "identity",
    "nodes",
    "relations",
    "execution",
    "downstream_policy",
    "completeness"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "ISSUE_EXECUTION_DECISION_V1"},
    "identity": {"$ref": "#/$defs/identity"},
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/node"}
    },
    "relations": {
      "type": "array",
      "items": {"$ref": "#/$defs/relation"}
    },
    "execution": {"$ref": "#/$defs/execution"},
    "downstream_policy": {"$ref": "#/$defs/downstream_policy"},
    "completeness": {"$ref": "#/$defs/completeness"}
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "issue_number": {
      "type": "integer",
      "minimum": 1
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_issue_number",
        "target_body_sha256",
        "generated_at",
        "collection_digest"
      ],
      "properties": {
        "target_issue_number": {"$ref": "#/$defs/issue_number"},
        "target_body_sha256": {"$ref": "#/$defs/sha256"},
        "generated_at": {"type": "string", "format": "date-time"},
        "collection_digest": {"$ref": "#/$defs/sha256"}
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_number", "body_sha256"],
      "properties": {
        "issue_number": {"$ref": "#/$defs/issue_number"},
        "body_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_issue_number",
        "target_issue_number",
        "relation_type",
        "evidence"
      ],
      "properties": {
        "source_issue_number": {"$ref": "#/$defs/issue_number"},
        "target_issue_number": {"$ref": "#/$defs/issue_number"},
        "relation_type": {
          "type": "string",
          "enum": ["depends_on", "duplicate", "absorb", "supersedes", "coordinates"]
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "target_issue_number", "predecessors", "defer_reason"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["selected", "deferred", "blocked", "duplicate"]
        },
        "target_issue_number": {"$ref": "#/$defs/issue_number"},
        "predecessors": {
          "type": "array",
          "items": {"$ref": "#/$defs/issue_number"}
        },
        "defer_reason": {
          "type": ["string", "null"],
          "minLength": 1
        }
      }
    },
    "downstream_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantic_reclassification",
        "freshness_validation",
        "stale_action"
      ],
      "properties": {
        "semantic_reclassification": {"type": "string", "const": "forbidden"},
        "freshness_validation": {"type": "string", "const": "required"},
        "stale_action": {"type": "string", "const": "rerun_issue_refinement"}
      }
    },
    "completeness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issues_complete",
        "dependencies_complete",
        "unresolved_references"
      ],
      "properties": {
        "issues_complete": {"type": "boolean"},
        "dependencies_complete": {"type": "boolean"},
        "unresolved_references": {
          "type": "array",
          "items": {"$ref": "#/$defs/issue_number"}
        }
      }
    }
  }
}

