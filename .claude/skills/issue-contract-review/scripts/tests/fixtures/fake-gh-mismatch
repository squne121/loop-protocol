#!/usr/bin/env bash
# fake-gh-mismatch: native API と fallback (Depends on #N) が不一致なスタブ
# native: Issue #10 のみ
# fallback: Issue body に "Depends on #20" が含まれる

set -euo pipefail

# api サブコマンド: dependencies/blocked_by
if [[ "$1" == "api" ]]; then
  echo '[{"number":10,"state":"closed","title":"Native blocker"}]'
  exit 0
fi

# issue view サブコマンド
if [[ "$1" == "issue" && "$2" == "view" ]]; then
  # --json body の場合 — fallback に #20 が含まれ、native の #10 とは不一致
  if [[ "$*" == *"--json body"* ]]; then
    echo '{"body":"Depends on #20\n\nThis is the issue body."}'
    exit 0
  fi
  # --json state の場合
  if [[ "$*" == *"--json state"* ]]; then
    echo "CLOSED"
    exit 0
  fi
fi

echo "fake-gh-mismatch: unhandled: $*" >&2
exit 1
