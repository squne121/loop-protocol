#!/usr/bin/env bash
# fake-gh-open-blocker: native API が open な blocker を 1 件返すスタブ
# Issue #10 が open な blocker として存在する

set -euo pipefail

# api サブコマンド: dependencies/blocked_by
if [[ "$1" == "api" ]]; then
  echo '[{"number":10,"state":"open","title":"Blocker issue"}]'
  exit 0
fi

# issue view サブコマンド
if [[ "$1" == "issue" && "$2" == "view" ]]; then
  # --json body の場合
  if [[ "$*" == *"--json body"* ]]; then
    echo '{"body":"This is the issue body with no Depends on."}'
    exit 0
  fi
  # --json state の場合
  if [[ "$*" == *"--json state"* ]]; then
    echo "OPEN"
    exit 0
  fi
fi

echo "fake-gh-open-blocker: unhandled: $*" >&2
exit 1
