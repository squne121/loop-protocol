# LOOP_PROTOCOL project-local command policy for Codex.
# This is intentionally stricter than `.claude/settings.json`: Codex uses `rtk`
# as the command harness, but only for explicitly allowlisted subcommands.
# Hooks + rules are a fail-closed local guardrail for repo workflow compliance.
# Known limitation: they are not a security boundary and can be weakened by
# parent runtime overrides, untrusted project state, or unsupported tool paths.
# Known limitation: `rtk` itself does not enforce policy; if `rtk` is absent or
# untrusted, the blanket-allow rule is removed to prevent bypass via `rtk` wrapping.

# ─── Session startup preflight gate (local_main_branch_guard) ─────────────────
# Before executing any implementation task, run the following mandatory gate:
#
#   uv run python3 scripts/check_local_main_branch_state.py --json
#
# If this exits non-zero, the local root checkout is not on the default branch.
# Do NOT proceed with implementation work until the local root is on the default branch.
# This is a required startup gate — failure to run it is a protocol violation.
# ─────────────────────────────────────────────────────────────────────────────

prefix_rule(
    pattern = ["rtk", "--help"],
    decision = "allow",
    justification = "Inspect the project harness interface before using it.",
    match = [
        "rtk --help",
    ],
)

# --- rtk gh: read / verify operations only ---

prefix_rule(
    pattern = ["rtk", "gh", ["issue", "pr", "api"]],
    decision = "allow",
    justification = "Allow read-only GitHub operations via rtk: issue view/list, pr view/list/checks/diff, api GET.",
    match = [
        "rtk gh issue view 1",
        "rtk gh issue list",
        "rtk gh pr view 1",
        "rtk gh pr list",
        "rtk gh pr checks 1",
        "rtk gh pr diff 1",
        "rtk gh api repos/squne121/loop-protocol",
    ],
)

# rtk gh mutation operations: require explicit human review (prompt)
prefix_rule(
    pattern = ["rtk", "gh", "pr", ["merge", "create", "close", "edit", "ready", "reopen"]],
    decision = "prompt",
    justification = "Mutating GitHub PR operations require explicit human review. More restrictive than the read allow above.",
    match = [
        "rtk gh pr merge 1",
        "rtk gh pr create",
        "rtk gh pr close 1",
        "rtk gh pr edit 1",
        "rtk gh pr ready 1",
    ],
)

prefix_rule(
    pattern = ["rtk", "gh", "issue", ["create", "edit", "close", "reopen", "delete"]],
    decision = "prompt",
    justification = "Mutating GitHub issue operations require explicit human review.",
    match = [
        "rtk gh issue create",
        "rtk gh issue edit 1",
        "rtk gh issue close 1",
    ],
)

prefix_rule(
    pattern = ["rtk", "gh", "release", ["create", "delete", "edit", "upload"]],
    decision = "prompt",
    justification = "GitHub release mutation requires explicit human review.",
    match = [
        "rtk gh release create v1.0.0",
    ],
)

# --- rtk git: read / verify operations only ---

prefix_rule(
    pattern = ["rtk", "git", ["status", "log", "diff", "branch", "show", "blame", "describe", "shortlog", "rev-parse", "ls-files", "ls-tree"]],
    decision = "allow",
    justification = "Allow read-only git inspection via rtk.",
    match = [
        "rtk git status",
        "rtk git log --oneline -5",
        "rtk git diff --stat",
        "rtk git branch --show-current",
    ],
)

# rtk git mutation operations: only the bounded publish shapes are allowlisted here.
# Issue #1611 (contract revision, AC9/AC14): `rtk git add` / `rtk git commit`
# are narrowed to `forbidden` -- staging/commit is now exclusively the
# controlled executor's job (`scripts/agent-guards/controlled_git_change_exec.py`,
# invoked as `uv run --locked python3 scripts/agent-guards/controlled_git_change_exec.py
# ...`), never a raw `git add`/`git commit` (or `rtk git add`/`rtk git commit`)
# shell shape. `git_mutation_command_policy.classify_agent_lane_add_commit`
# denies the same shapes at the PreToolUse guard layer (defense in depth --
# this static rule and that runtime guard must both deny).
prefix_rule(
    pattern = ["rtk", "git", "add"],
    decision = "forbidden",
    justification = "Issue #1611: staging is exclusively the controlled executor's job (scripts/agent-guards/controlled_git_change_exec.py); raw `rtk git add` is never allowed for the agent lane.",
    match = [
        "rtk git add docs/dev/hook-boundaries.md",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", "commit", "-m"],
    decision = "forbidden",
    justification = "Issue #1611: commit is exclusively the controlled executor's job (scripts/agent-guards/controlled_git_change_exec.py); raw `rtk git commit` is never allowed for the agent lane.",
    match = [
        "rtk git commit -m issue-1241-update",
    ],
)

# --- controlled stage/commit executor (Issue #1611): the ONLY authorized ---
# --- path for agent-driven git staging/commit. Runtime binding checks    ---
# --- (repository/worktree/branch/HEAD, Allowed Paths, protected paths)   ---
# --- happen inside the executor itself -- this static rule only allows   ---
# --- the exact `uv run --locked python3` invocation prefix; extra argv,  ---
# --- a `bash -lc` wrapper, or invocation from outside a linked issue     ---
# --- worktree are all denied by the executor's own fail-closed checks.   ---
prefix_rule(
    pattern = ["uv", "run", "--locked", "python3", "scripts/agent-guards/controlled_git_change_exec.py"],
    decision = "allow",
    justification = "Issue #1611: the controlled stage/commit executor is the single authorized in-process path for agent-driven git add/commit; its own runtime checks (repository/worktree/branch/HEAD binding, Allowed Paths, protected paths, audit-then-rollback) are the actual enforcement, not this static allow.",
    match = [
        "uv run --locked python3 scripts/agent-guards/controlled_git_change_exec.py --cwd .claude/worktrees/issue-1611-x --snapshot-json .claude/tmp/issue-1611-scope-snapshot.json --path scripts/agent-guards/example.py --message \"feat: example\" --expected-head 0000000000000000000000000000000000000000",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", "push", "origin"],
    decision = "allow",
    justification = "Issue-worktree publish path is allowed only when the runtime hooks validate the active-branch refspec and deny force/tag/all/mirror/delete forms.",
    match = [
        "rtk git push origin HEAD:refs/heads/worktree-issue-1241-x",
    ],
)

# Other rtk git mutation operations: require explicit human review (prompt)
prefix_rule(
    pattern = ["rtk", "git", ["checkout", "switch", "worktree", "stash", "merge", "rebase", "cherry-pick", "reset", "restore", "rm", "mv", "clean", "apply", "am", "pull", "fetch", "remote", "tag", "config", "submodule"]],
    decision = "prompt",
    justification = "Mutating git operations via rtk require explicit human review.",
    match = [
        "rtk git checkout -b topic",
    ],
)

# --- rtk pnpm: validation and build operations ---

prefix_rule(
    pattern = ["rtk", "pnpm", ["test", "lint", "typecheck", "build", "exec", "run"]],
    decision = "allow",
    justification = "Allow validation and build rtk pnpm subcommands.",
    match = [
        "rtk pnpm test",
        "rtk pnpm lint",
        "rtk pnpm typecheck",
        "rtk pnpm build",
        "rtk pnpm exec node scripts/check-codex-agents.mjs",
    ],
)

# rtk pnpm dependency mutation: require explicit human review (prompt)
prefix_rule(
    pattern = ["rtk", "pnpm", ["add", "remove", "install", "uninstall", "update", "upgrade"]],
    decision = "prompt",
    justification = "Dependency mutations via rtk pnpm require explicit human review.",
    match = [
        "rtk pnpm add lodash",
        "rtk pnpm remove lodash",
        "rtk pnpm install",
    ],
)

# --- direct node invocation for validator ---

prefix_rule(
    pattern = ["node", "scripts/check-codex-agents.mjs"],
    decision = "allow",
    justification = "Allow the Codex custom-agent validator and hook entrypoint.",
    match = [
        "node scripts/check-codex-agents.mjs",
        "node scripts/check-codex-agents.mjs --self-test",
    ],
)

# --- codex runtime smoke ---

prefix_rule(
    pattern = ["codex", ["--version", "execpolicy", "exec"]],
    decision = "allow",
    justification = "Allow documented runtime smoke tests for custom agent spawn and local guardrail behavior.",
    match = [
        "codex --version",
        "codex execpolicy check --rules .codex/rules/default.rules rtk gh issue view 1",
        "codex exec \"Spawn the codebase-investigator custom agent once\"",
    ],
)

# --- rtk read-oriented helpers ---

prefix_rule(
    pattern = ["rtk", ["ls", "read", "find", "grep", "wc", "diff", "log", "summary", "json", "test", "tsc", "lint", "vitest", "pytest", "mypy", "ruff", "prettier", "format"]],
    decision = "allow",
    justification = "Allow read-oriented and verification-oriented rtk helpers.",
    match = [
        "rtk ls",
        "rtk read README.md",
        "rtk lint .",
    ],
)

prefix_rule(
    pattern = ["rtk", ["curl", "env"]],
    decision = "prompt",
    justification = "Network and environment inspection can expose secrets or remote content; require explicit review.",
    match = [
        "rtk curl https://api.github.com/repos/squne121/loop-protocol",
        "rtk env",
    ],
)

# --- DIRECT_ALLOW: specific pnpm / git / gh operations (Issue #874) ---
# DIRECT_ALLOW が成立するのは、競合する broad forbidden を mutation-only に狭めているため。
# Codex rules は prefix-specificity 優先ではなく、複数 match 時は most restrictive decision が勝つ。
# これらのルールは blanket-forbidden rule と競合しているが、allow 側に fallback できるのは
# forbidden 対象が mutation コマンド (e.g. pnpm add/install) に限定されているからである。
# 最終 decision は codex execpolicy check で検証すること。

# DIRECT_ALLOW_PNPM: validation commands allowed directly (no rtk wrapper needed in hook context)
prefix_rule(
    pattern = ["pnpm", ["typecheck", "lint", "test", "build"]],
    decision = "allow",
    justification = "Validation commands pnpm typecheck/lint/test/build are always safe and required for CI.",
    match = [
        "pnpm typecheck",
        "pnpm lint",
        "pnpm test",
        "pnpm build",
    ],
)

# DIRECT_ALLOW_GIT: read-only git inspection allowed directly.
# Issue #1137: `branch` removed from this broad allow so `git branch -d/-D` is not
# statically allowed; read-only branch forms are allowed by the granular rules below.
prefix_rule(
    pattern = ["git", ["status", "diff", "log", "show", "rev-parse", "ls-files"]],
    decision = "allow",
    justification = "Read-only git inspection is safe; more specific than the mutation-forbidden rule below.",
    match = [
        "git status",
        "git diff",
        "git log --oneline -5",
        "git show HEAD",
        "git rev-parse HEAD",
        "git ls-files",
    ],
)

# DIRECT_ALLOW_GH: read-only GitHub operations allowed directly
prefix_rule(
    pattern = ["gh", "issue", ["view", "list"]],
    decision = "allow",
    justification = "gh issue view/list are read-only and safe.",
    match = [
        "gh issue view 1",
        "gh issue list",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", ["view", "list", "checks", "diff"]],
    decision = "allow",
    justification = "gh pr view/list/checks/diff are read-only and safe.",
    match = [
        "gh pr view 1",
        "gh pr list",
        "gh pr checks 1",
        "gh pr diff 1",
    ],
)

# --- direct git read-only (Claude Code environment) ---

prefix_rule(
    pattern = ["git", "branch", "--show-current"],
    decision = "allow",
    justification = "Read-only git inspection is allowed.",
    match = [
        "git branch --show-current",
    ],
)

prefix_rule(
    pattern = ["git", "log"],
    decision = "allow",
    justification = "Read-only git inspection is allowed.",
    match = [
        "git log --oneline -5",
        "git log --stat",
    ],
)

prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    justification = "Read-only git inspection is allowed.",
    match = [
        "git status",
        "git status --short",
    ],
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
    justification = "Read-only git inspection is allowed.",
    match = [
        "git diff",
        "git diff --stat",
    ],
)

prefix_rule(
    pattern = ["git", ["push", "commit", "checkout", "switch", "stash", "merge", "rebase", "cherry-pick", "reset", "restore", "add", "rm", "mv", "clean", "apply", "am", "pull", "fetch", "remote", "tag", "config", "submodule"]],
    decision = "forbidden",
    justification = "Use `rtk git ...` for mutating repository operations so project policy is applied.",
    match = [
        "git commit -m update",
        "git push",
        "git checkout -b topic",
        "git add AGENTS.md",
        "git fetch origin",
    ],
)

# --- Issue #1137: cleanup exact commands on the guarded cleanup route ---
# `git worktree`/`git branch` are split so the exact cleanup commands are NOT
# statically allowed and NOT broadly forbidden, but routed to worktree_scope_guard
# (the guarded cleanup route, wired in .codex/hooks.json) against the V3 one-shot
# contract. Force / destructive variants stay forbidden; read-only forms allowed.

prefix_rule(
    pattern = ["git", "worktree", "list"],
    decision = "allow",
    justification = "git worktree list is read-only.",
    match = ["git worktree list", "git worktree list --porcelain"],
)

prefix_rule(
    pattern = ["git", "worktree", "remove"],
    decision = "prompt",
    justification = "Exact `git worktree remove` is a cleanup command on the guarded cleanup route; worktree_scope_guard arbitrates it against the V3 one-shot contract. Not static-allowed.",
    match = ["git worktree remove .claude/worktrees/issue-1-x"],
)

prefix_rule(
    pattern = ["git", "worktree", ["add", "move", "lock", "unlock", "prune", "repair"]],
    decision = "forbidden",
    justification = "Non-cleanup worktree mutations require the rtk git wrapper.",
    match = ["git worktree add ../tmp main", "git worktree prune"],
)

prefix_rule(
    pattern = ["git", "branch", ["--show-current", "--list", "-l", "-a", "-r", "-v", "-vv"]],
    decision = "allow",
    justification = "Read-only git branch inspection is safe.",
    match = ["git branch --show-current", "git branch --list", "git branch -a"],
)

prefix_rule(
    pattern = ["git", "branch", "-d"],
    decision = "prompt",
    justification = "Exact `git branch -d` is a cleanup command on the guarded cleanup route; worktree_scope_guard arbitrates it against the V3 one-shot contract. Not static-allowed.",
    match = ["git branch -d issue-1-x"],
)

prefix_rule(
    pattern = ["git", "branch", ["-D", "-f", "--force", "--delete", "-m", "-M"]],
    decision = "forbidden",
    justification = "Force / rename branch operations are forbidden; the runtime hook also denies branch_force_delete_denied.",
    match = ["git branch -D x", "git branch -f x", "git branch -m old new"],
)

prefix_rule(
    pattern = ["pnpm", ["add", "remove", "install", "uninstall", "update", "upgrade", "exec", "run", "dlx", "publish", "pack"]],
    decision = "forbidden",
    justification = "Dependency mutation and exec operations require rtk pnpm wrapper. Use rtk pnpm for these.",
    match = [
        "pnpm add lodash",
        "pnpm install",
        "pnpm exec node ...",
        "pnpm run custom-script",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", ["merge", "create", "close", "edit", "ready", "reopen", "review"]],
    decision = "forbidden",
    justification = "Mutating GitHub PR operations require rtk gh wrapper.",
    match = [
        "gh pr merge 1",
        "gh pr create",
        "gh pr close 1",
        "gh pr edit 1",
    ],
)

prefix_rule(
    pattern = ["gh", "issue", ["create", "edit", "close", "reopen", "delete", "comment"]],
    decision = "forbidden",
    justification = "Mutating GitHub issue operations require rtk gh wrapper or managed skill context. Exception: github_issue_mutation_command (gh issue create/edit with --repo squne121/loop-protocol and --body-file tmp/<path>) is allowed via managed skill (create-issue / edit-issue). Bare gh issue create/edit without required flags remain forbidden. See docs/dev/hook-boundaries.md for 5-class taxonomy.",
    match = [
        "gh issue create",
        "gh issue edit 1",
        "gh issue close 1",
        "gh issue comment 1",
    ],
)

prefix_rule(
    pattern = ["gh", "release"],
    decision = "forbidden",
    justification = "GitHub release operations require rtk gh wrapper.",
    match = [
        "gh release create v1.0.0",
    ],
)

prefix_rule(
    pattern = ["gh", "secret"],
    decision = "forbidden",
    justification = "GitHub secret operations are forbidden.",
    match = [
        "gh secret list",
        "gh secret set FOO bar",
    ],
)
