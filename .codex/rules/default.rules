# LOOP_PROTOCOL project-local command policy for Codex.
# This is intentionally stricter than `.claude/settings.json`: Codex uses `rtk`
# as the command harness, but only for explicitly allowlisted subcommands.
# Hooks + rules are a fail-closed local guardrail for repo workflow compliance.
# Known limitation: they are not a security boundary and can be weakened by
# parent runtime overrides, untrusted project state, or unsupported tool paths.
# Known limitation: `rtk` itself does not enforce policy; if `rtk` is absent or
# untrusted, the blanket-allow rule is removed to prevent bypass via `rtk` wrapping.

# ─── Session startup preflight gate (local_main_branch_guard) ─────────────────
# Before executing any implementation task, run the following mandatory gate:
#
#   uv run python3 scripts/check_local_main_branch_state.py --json
#
# If this exits non-zero, the local root checkout is not on the default branch.
# Do NOT proceed with implementation work until the local root is on the default branch.
# This is a required startup gate — failure to run it is a protocol violation.
# ─────────────────────────────────────────────────────────────────────────────

prefix_rule(
    pattern = ["rtk", "--help"],
    decision = "allow",
    justification = "Inspect the project harness interface before using it.",
    match = [
        "rtk --help",
    ],
)

# --- rtk gh: read / verify operations only ---

prefix_rule(
    pattern = ["rtk", "gh", ["issue", "pr", "api"]],
    decision = "allow",
    justification = "Allow read-only GitHub operations via rtk: issue view/list, pr view/list/checks/diff, api GET.",
    match = [
        "rtk gh issue view 1",
        "rtk gh issue list",
        "rtk gh pr view 1",
        "rtk gh pr list",
        "rtk gh pr checks 1",
        "rtk gh pr diff 1",
        "rtk gh api repos/squne121/loop-protocol",
    ],
)

# rtk gh mutation operations: require explicit human review (prompt)
prefix_rule(
    pattern = ["rtk", "gh", "pr", ["merge", "create", "close", "edit", "ready", "reopen"]],
    decision = "prompt",
    justification = "Mutating GitHub PR operations require explicit human review. More restrictive than the read allow above.",
    match = [
        "rtk gh pr merge 1",
        "rtk gh pr create",
        "rtk gh pr close 1",
        "rtk gh pr edit 1",
        "rtk gh pr ready 1",
    ],
)

prefix_rule(
    pattern = ["rtk", "gh", "issue", ["create", "edit", "close", "reopen", "delete"]],
    decision = "prompt",
    justification = "Mutating GitHub issue operations require explicit human review.",
    match = [
        "rtk gh issue create",
        "rtk gh issue edit 1",
        "rtk gh issue close 1",
    ],
)

prefix_rule(
    pattern = ["rtk", "gh", "release", ["create", "delete", "edit", "upload"]],
    decision = "prompt",
    justification = "GitHub release mutation requires explicit human review.",
    match = [
        "rtk gh release create v1.0.0",
    ],
)

# --- rtk git: read / verify operations only ---

prefix_rule(
    pattern = ["rtk", "git", ["status", "log", "diff", "branch", "show", "blame", "describe", "shortlog", "rev-parse", "ls-files", "ls-tree"]],
    decision = "allow",
    justification = "Allow read-only git inspection via rtk.",
    match = [
        "rtk git status",
        "rtk git log --oneline -5",
        "rtk git diff --stat",
        "rtk git branch --show-current",
    ],
)

# rtk git mutation operations: require explicit human review (prompt)
prefix_rule(
    pattern = ["rtk", "git", ["push", "commit", "add", "checkout", "switch", "worktree", "stash", "merge", "rebase", "cherry-pick", "reset", "restore", "rm", "mv", "clean", "apply", "am", "pull", "fetch", "remote", "tag", "config", "submodule"]],
    decision = "prompt",
    justification = "Mutating git operations via rtk require explicit human review.",
    match = [
        "rtk git push",
        "rtk git commit -m update",
        "rtk git checkout -b topic",
    ],
)

# --- rtk pnpm: validation and build operations ---

prefix_rule(
    pattern = ["rtk", "pnpm", ["test", "lint", "typecheck", "build", "exec", "run"]],
    decision = "allow",
    justification = "Allow validation and build rtk pnpm subcommands.",
    match = [
        "rtk pnpm test",
        "rtk pnpm lint",
        "rtk pnpm typecheck",
        "rtk pnpm build",
        "rtk pnpm exec node scripts/check-codex-agents.mjs",
    ],
)

# rtk pnpm dependency mutation: require explicit human review (prompt)
prefix_rule(
    pattern = ["rtk", "pnpm", ["add", "remove", "install", "uninstall", "update", "upgrade"]],
    decision = "prompt",
    justification = "Dependency mutations via rtk pnpm require explicit human review.",
    match = [
        "rtk pnpm add lodash",
        "rtk pnpm remove lodash",
        "rtk pnpm install",
    ],
)

# --- direct node invocation for validator ---

prefix_rule(
    pattern = ["node", "scripts/check-codex-agents.mjs"],
    decision = "allow",
    justification = "Allow the Codex custom-agent validator and hook entrypoint.",
    match = [
        "node scripts/check-codex-agents.mjs",
        "node scripts/check-codex-agents.mjs --self-test",
    ],
)

# --- codex runtime smoke ---

prefix_rule(
    pattern = ["codex", ["--version", "execpolicy", "exec"]],
    decision = "allow",
    justification = "Allow documented runtime smoke tests for custom agent spawn and local guardrail behavior.",
    match = [
        "codex --version",
        "codex execpolicy check --rules .codex/rules/default.rules rtk gh issue view 1",
        "codex exec \"Spawn the codebase-investigator custom agent once\"",
    ],
)

# --- rtk read-oriented helpers ---

prefix_rule(
    pattern = ["rtk", ["ls", "read", "find", "grep", "wc", "diff", "log", "summary", "json", "test", "tsc", "lint", "vitest", "pytest", "mypy", "ruff", "prettier", "format"]],
    decision = "allow",
    justification = "Allow read-oriented and verification-oriented rtk helpers.",
    match = [
        "rtk ls",
        "rtk read README.md",
        "rtk lint .",
    ],
)

prefix_rule(
    pattern = ["rtk", ["curl", "env"]],
    decision = "prompt",
    justification = "Network and environment inspection can expose secrets or remote content; require explicit review.",
    match = [
        "rtk curl https://api.github.com/repos/squne121/loop-protocol",
        "rtk env",
    ],
)

# --- DIRECT_ALLOW: specific pnpm / git / gh operations (Issue #874) ---
# DIRECT_ALLOW が成立するのは、競合する broad forbidden を mutation-only に狭めているため。
# Codex rules は prefix-specificity 優先ではなく、複数 match 時は most restrictive decision が勝つ。
# これらのルールは blanket-forbidden rule と競合しているが、allow 側に fallback できるのは
# forbidden 対象が mutation コマンド (e.g. pnpm add/install) に限定されているからである。
# 最終 decision は codex execpolicy check で検証すること。

# DIRECT_ALLOW_PNPM: validation commands allowed directly (no rtk wrapper needed in hook context)
prefix_rule(
    pattern = ["pnpm", ["typecheck", "lint", "test", "build"]],
    decision = "allow",
    justification = "Validation commands pnpm typecheck/lint/test/build are always safe and required for CI.",
    match = [
        "pnpm typecheck",
        "pnpm lint",
        "pnpm test",
        "pnpm build",
    ],
)

# DIRECT_ALLOW_GIT: read-only git inspection allowed directly
prefix_rule(
    pattern = ["git", ["status", "diff", "log", "branch", "show", "rev-parse", "ls-files"]],
    decision = "allow",
    justification = "Read-only git inspection is safe; more specific than the mutation-forbidden rule below.",
    match = [
        "git status",
        "git diff",
        "git log --oneline -5",
        "git branch --show-current",
        "git show HEAD",
        "git rev-parse HEAD",
        "git ls-files",
    ],
)

# DIRECT_ALLOW_GH: read-only GitHub operations allowed directly
prefix_rule(
    pattern = ["gh", "issue", ["view", "list"]],
    decision = "allow",
    justification = "gh issue view/list are read-only and safe.",
    match = [
        "gh issue view 1",
        "gh issue list",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", ["view", "list", "checks", "diff"]],
    decision = "allow",
    justification = "gh pr view/list/checks/diff are read-only and safe.",
    match = [
        "gh pr view 1",
        "gh pr list",
        "gh pr checks 1",
        "gh pr diff 1",
    ],
)

# --- direct git read-only (Claude Code environment) ---

prefix_rule(
    pattern = ["git", "branch", "--show-current"],
    decision = "allow",
    justification = "Read-only git inspection is allowed.",
    match = [
        "git branch --show-current",
    ],
)

prefix_rule(
    pattern = ["git", "log"],
    decision = "allow",
    justification = "Read-only git inspection is allowed.",
    match = [
        "git log --oneline -5",
        "git log --stat",
    ],
)

prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    justification = "Read-only git inspection is allowed.",
    match = [
        "git status",
        "git status --short",
    ],
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
    justification = "Read-only git inspection is allowed.",
    match = [
        "git diff",
        "git diff --stat",
    ],
)

prefix_rule(
    pattern = ["git", ["push", "commit", "checkout", "switch", "worktree", "stash", "merge", "rebase", "cherry-pick", "reset", "restore", "add", "rm", "mv", "clean", "apply", "am", "pull", "fetch", "remote", "tag", "config", "submodule"]],
    decision = "forbidden",
    justification = "Use `rtk git ...` for mutating repository operations so project policy is applied.",
    match = [
        "git commit -m update",
        "git push",
        "git checkout -b topic",
        "git worktree add ../tmp main",
        "git add AGENTS.md",
        "git fetch origin",
    ],
)

prefix_rule(
    pattern = ["pnpm", ["add", "remove", "install", "uninstall", "update", "upgrade", "exec", "run", "dlx", "publish", "pack"]],
    decision = "forbidden",
    justification = "Dependency mutation and exec operations require rtk pnpm wrapper. Use rtk pnpm for these.",
    match = [
        "pnpm add lodash",
        "pnpm install",
        "pnpm exec node ...",
        "pnpm run custom-script",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", ["merge", "create", "close", "edit", "ready", "reopen", "review"]],
    decision = "forbidden",
    justification = "Mutating GitHub PR operations require rtk gh wrapper.",
    match = [
        "gh pr merge 1",
        "gh pr create",
        "gh pr close 1",
        "gh pr edit 1",
    ],
)

prefix_rule(
    pattern = ["gh", "issue", ["create", "edit", "close", "reopen", "delete", "comment"]],
    decision = "forbidden",
    justification = "Mutating GitHub issue operations require rtk gh wrapper.",
    match = [
        "gh issue create",
        "gh issue edit 1",
        "gh issue close 1",
        "gh issue comment 1",
    ],
)

prefix_rule(
    pattern = ["gh", "release"],
    decision = "forbidden",
    justification = "GitHub release operations require rtk gh wrapper.",
    match = [
        "gh release create v1.0.0",
    ],
)

prefix_rule(
    pattern = ["gh", "secret"],
    decision = "forbidden",
    justification = "GitHub secret operations are forbidden.",
    match = [
        "gh secret list",
        "gh secret set FOO bar",
    ],
)
