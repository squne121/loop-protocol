{
  "hooks": {
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/scripts/check-codex-agents.mjs\" --hook-subagent-start",
            "timeout": 30,
            "statusMessage": "Loading LOOP_PROTOCOL subagent guardrail"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/local_main_branch_guard.sh\"",
            "timeout": 10,
            "statusMessage": "Checking local root branch policy"
          },
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/scripts/check-codex-agents.mjs\" --hook-pretool",
            "timeout": 30,
            "statusMessage": "Checking LOOP_PROTOCOL Bash guardrail"
          },
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-recording-composite.mjs\" --event PreToolUse",
            "timeout": 30,
            "statusMessage": "Checking Codex session-recording PreToolUse guard"
          }
        ]
      },
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/scripts/check-codex-agents.mjs\" --hook-pretool",
            "timeout": 30,
            "statusMessage": "Checking LOOP_PROTOCOL patch guardrail"
          },
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-recording-composite.mjs\" --event PreToolUse",
            "timeout": 30,
            "statusMessage": "Checking Codex session-recording patch guard"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/local_main_branch_guard.sh\"",
            "timeout": 10,
            "statusMessage": "Checking local root branch policy"
          },
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-recording-composite.mjs\" --event PermissionRequest",
            "timeout": 30,
            "statusMessage": "Checking Codex session-recording PermissionRequest guard"
          }
        ]
      },
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-recording-composite.mjs\" --event PermissionRequest",
            "timeout": 30,
            "statusMessage": "Checking Codex session-recording PermissionRequest guard"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-recording-composite.mjs\" --event Stop",
            "timeout": 30,
            "statusMessage": "Writing Codex session-recording Stop manifest"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-recording-composite.mjs\" --event SubagentStop",
            "timeout": 30,
            "statusMessage": "Writing Codex session-recording SubagentStop manifest"
          }
        ]
      }
    ]
  }
}
