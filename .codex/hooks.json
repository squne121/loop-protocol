{
  "fastpathContract": {
    "_comment": "Issue #1289: pretool_fastpath_classifier.py is a shared library imported by local_main_branch_guard (invoked via the local_main_branch_guard.sh command below); it is NOT registered as its own PreToolUse hook entry here. classification vocabulary: readonly_display / exact_controlled_executor_authorized / mutation_or_unknown. failPolicy: fail_open (telemetry only, never changes the allow/block decision of the guard chain below). stdoutContract: silent (pure Python function; the calling guard's own stdout/stderr contract is unchanged).",
    "module": "scripts/agent-guards/pretool_fastpath_classifier.py",
    "classification": ["readonly_display", "exact_controlled_executor_authorized", "mutation_or_unknown"],
    "failPolicy": "fail_open",
    "stdoutContract": "silent",
    "stderrContract": "silent",
    "registeredAsIndependentHook": false
  },
  "hooks": {
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/scripts/check-codex-agents.mjs\" --hook-subagent-start",
            "timeout": 30,
            "statusMessage": "Loading LOOP_PROTOCOL subagent guardrail"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/local_main_branch_guard.sh\"",
            "timeout": 10,
            "statusMessage": "Checking local root branch policy"
          },
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.claude/hooks/worktree_scope_guard.py\"",
            "timeout": 20,
            "statusMessage": "Checking worktree cleanup scope policy (shared core)"
          },
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/scripts/check-codex-agents.mjs\" --hook-pretool",
            "timeout": 30,
            "statusMessage": "Checking LOOP_PROTOCOL Bash guardrail"
          },
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-recording-composite.mjs\" --event PreToolUse",
            "timeout": 30,
            "statusMessage": "Checking Codex session-recording PreToolUse guard"
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/ci_test_performance_advisory.sh\"",
            "timeout": 10,
            "statusMessage": "Checking CI/test-lane path advisory"
          }
        ]
      },
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/scripts/check-codex-agents.mjs\" --hook-pretool",
            "timeout": 30,
            "statusMessage": "Checking LOOP_PROTOCOL patch guardrail"
          },
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-recording-composite.mjs\" --event PreToolUse",
            "timeout": 30,
            "statusMessage": "Checking Codex session-recording patch guard"
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/ci_test_performance_advisory.sh\"",
            "timeout": 10,
            "statusMessage": "Checking CI/test-lane path advisory"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/local_main_branch_guard.sh\"",
            "timeout": 10,
            "statusMessage": "Checking local root branch policy"
          },
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-recording-composite.mjs\" --event PermissionRequest",
            "timeout": 30,
            "statusMessage": "Checking Codex session-recording PermissionRequest guard"
          }
        ]
      },
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-recording-composite.mjs\" --event PermissionRequest",
            "timeout": 30,
            "statusMessage": "Checking Codex session-recording PermissionRequest guard"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-recording-composite.mjs\" --event Stop",
            "timeout": 30,
            "statusMessage": "Writing Codex session-recording Stop manifest"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "rtk pnpm exec node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-recording-composite.mjs\" --event SubagentStop",
            "timeout": 30,
            "statusMessage": "Writing Codex session-recording SubagentStop manifest"
          }
        ]
      }
    ]
  }
}
