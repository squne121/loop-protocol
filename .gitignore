# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# NotebookLM local assets
.nlm-local/
# REPOSITORY_FOLDER_POLICY_V1: /tmp/ is the repo-approved local temporary workspace at repo root only.
/tmp/
/tmp/nlm/

# Project-local tmp working files (issue backups / intermediate body / reviewer feedback など)
# `tmp/` 自体は create-issue / edit-issue / post-merge-cleanup の作業領域として使うが、
# 中身（バックアップ・中間ファイル）はコミットしない
/tmp/session-manifests/codex/
/tmp/codex-pilot-metrics.json
/tmp/issue_*_backup_*.md
/tmp/issue_*_new_*.md
/tmp/reviewer_feedback.md
/tmp/edit_issue_*.md
.agents/skills/nlm-skill/SKILL.md

# Local AI workspace settings
# Serena MCP local project/runtime state generated by live probes.
.serena/
# .agents/ 配下: 流用 skill が前提とする rules / shared-agent-skills-governance はリポジトリで管理する
.agents/skills/nlm-skill/
# Codex repo-shared skill surface lives under .agents/skills/ and is tracked unless explicitly ignored above.
# `.codex/skills` は local-only compatibility / symlink 用であり、repo-shared surface としては使わない。
# .claude/ 配下: nlm-skill / worktree / plans 等の一時領域のみ除外
.claude/skills/nlm-skill/
# .system/ は ESLint では eslint.config.mjs 側で ignore 済みだが、git status / dirty tree に残り続けるため除外
.claude/skills/.system/
.claude/skills/*-workspace/
.claude/tmp/
.claude/worktrees/
.claude/plans/
# 個人ローカル上書き（API キー / ローカルパス / 好み等）。共有設定は .claude/settings.json に残す
.claude/settings.local.json
# repo root の project-local pnpm store（root 限定）
/.pnpm-store/

# Guard shadow log (write-guard observability, local only)
.guard_shadow_log.jsonl

# Python runtime artifacts
.venv/
__pycache__/
.pytest_cache/

# LOCAL_MAIN_SCRATCH_ALLOW_V1 safe scratch prefixes (Issue #974)
# These paths are allowed for Write/Edit/MultiEdit from local main context.
artifacts/
playwright-report/
test-results/
coverage/
.cache/
