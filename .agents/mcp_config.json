{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena@3c241bab0d07d8adba8ef4f6c49676c954559dee",
        "serena",
        "start-mcp-server",
        "--project-from-cwd"
      ],
      "trust": false,
      "includeTools": [
        "find_file",
        "find_referencing_symbols",
        "find_symbol",
        "get_symbols_overview",
        "list_dir",
        "search_for_pattern"
      ],
      "excludeTools": [
        "activate_project",
        "create_text_file",
        "delete_memory",
        "edit_memory",
        "execute_shell_command",
        "find_declaration",
        "find_implementations",
        "get_current_config",
        "get_diagnostics_for_file",
        "initial_instructions",
        "insert_after_symbol",
        "insert_before_symbol",
        "list_memories",
        "onboarding",
        "read_file",
        "read_memory",
        "rename_memory",
        "rename_symbol",
        "replace_content",
        "replace_in_files",
        "replace_symbol_body",
        "safe_delete_symbol",
        "write_memory"
      ]
    }
  }
}
