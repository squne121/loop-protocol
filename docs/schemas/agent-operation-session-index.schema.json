{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent_operation_session_index/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "repo",
    "parent_issue",
    "target",
    "operation",
    "agent_run",
    "public_artifacts",
    "verification"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "agent_operation_session_index/v1"
    },
    "repo": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
      "maxLength": 200
    },
    "parent_issue": {
      "type": "integer",
      "minimum": 1
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "number"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "issue",
            "pull_request"
          ]
        },
        "number": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "github_event_ref",
        "occurred_at"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "issue_comment",
            "issue_body_update",
            "issue_close",
            "pr_open",
            "pr_comment",
            "pr_review_submitted",
            "pr_review_comment_created",
            "pr_review_thread_resolved",
            "commit_push",
            "ci_retry",
            "merge"
          ]
        },
        "github_event_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "ref",
            "digest"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "github_issue",
                "github_pr",
                "github_comment",
                "workflow_run"
              ]
            },
            "ref": {
              "type": "string",
              "minLength": 1,
              "maxLength": 400
            },
            "digest": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          }
        },
        "source": {
          "type": "object",
          "oneOf": [
            {
              "additionalProperties": false,
              "required": [
                "kind",
                "review_id",
                "node_id",
                "pull_number",
                "state",
                "commit_id",
                "submitted_at",
                "html_url",
                "digest"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "github_pull_request_review"
                },
                "review_id": {
                  "type": "integer",
                  "minimum": 1
                },
                "node_id": {
                  "type": "string",
                  "pattern": "^PRR_[A-Za-z0-9_]+$",
                  "maxLength": 200
                },
                "pull_number": {
                  "type": "integer",
                  "minimum": 1
                },
                "state": {
                  "type": "string",
                  "enum": [
                    "APPROVED",
                    "CHANGES_REQUESTED",
                    "COMMENTED",
                    "DISMISSED",
                    "PENDING"
                  ]
                },
                "commit_id": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{40}$"
                },
                "submitted_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "html_url": {
                  "type": "string",
                  "format": "uri",
                  "pattern": "^https://github\\.com/squne121/loop-protocol/pull/[0-9]+#pullrequestreview-[0-9]+$",
                  "maxLength": 300
                },
                "digest": {
                  "type": "string",
                  "pattern": "^sha256:[0-9a-f]{64}$"
                }
              }
            },
            {
              "additionalProperties": false,
              "required": [
                "kind",
                "comment_id",
                "node_id",
                "review_id",
                "pull_number",
                "path",
                "line",
                "commit_id",
                "created_at",
                "updated_at",
                "html_url",
                "digest"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "github_pull_request_review_comment"
                },
                "comment_id": {
                  "type": "integer",
                  "minimum": 1
                },
                "node_id": {
                  "type": "string",
                  "pattern": "^PRRC_[A-Za-z0-9_]+$",
                  "maxLength": 200
                },
                "review_id": {
                  "type": "integer",
                  "minimum": 1
                },
                "pull_number": {
                  "type": "integer",
                  "minimum": 1
                },
                "path": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 300
                },
                "line": {
                  "type": "integer",
                  "minimum": 1
                },
                "commit_id": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{40}$"
                },
                "created_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "updated_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "html_url": {
                  "type": "string",
                  "format": "uri",
                  "pattern": "^https://github\\.com/squne121/loop-protocol/pull/[0-9]+#discussion_r[0-9]+$",
                  "maxLength": 300
                },
                "digest": {
                  "type": "string",
                  "pattern": "^sha256:[0-9a-f]{64}$"
                }
              }
            },
            {
              "additionalProperties": false,
              "required": [
                "kind",
                "thread_node_id",
                "pull_number",
                "path",
                "line",
                "subject_type",
                "is_resolved",
                "origin",
                "digest"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "github_pull_request_review_thread"
                },
                "thread_node_id": {
                  "type": "string",
                  "pattern": "^PRRT_[A-Za-z0-9_]+$",
                  "maxLength": 200
                },
                "pull_number": {
                  "type": "integer",
                  "minimum": 1
                },
                "path": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 300
                },
                "line": {
                  "type": "integer",
                  "minimum": 1
                },
                "subject_type": {
                  "type": "string",
                  "enum": [
                    "LINE",
                    "FILE"
                  ]
                },
                "is_resolved": {
                  "type": "boolean"
                },
                "origin": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "mode",
                    "is_resolved",
                    "observed_at"
                  ],
                  "properties": {
                    "mode": {
                      "type": "string",
                      "enum": [
                        "live_api_snapshot"
                      ]
                    },
                    "is_resolved": {
                      "type": "boolean"
                    },
                    "observed_at": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                },
                "digest": {
                  "type": "string",
                  "pattern": "^sha256:[0-9a-f]{64}$"
                }
              }
            }
          ]
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "agent_run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "agent_surface",
        "evidence_mode",
        "capability_verdict",
        "raw_values_emitted"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "agent_surface": {
          "type": "string",
          "enum": [
            "claude_code",
            "codex_cli",
            "google_antigravity",
            "unknown"
          ]
        },
        "evidence_mode": {
          "type": "string",
          "enum": [
            "synthetic_route_proof",
            "synthetic_only",
            "real_pilot_verified"
          ]
        },
        "capability_verdict": {
          "type": "string",
          "enum": [
            "supported",
            "partial",
            "unsupported",
            "unverified"
          ]
        },
        "raw_values_emitted": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "public_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_report_comment_url",
        "run_report_payload_digest",
        "retro_index_comment_url",
        "retro_index_payload_digest",
        "retro_index_source_set_digest",
        "chatgpt_marker_comment_url",
        "chatgpt_marker_digest"
      ],
      "properties": {
        "run_report_comment_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github\\.com/squne121/loop-protocol/(issues|pull)/[0-9]+#issuecomment-[0-9]+$",
          "maxLength": 300
        },
        "run_report_payload_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "retro_index_comment_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github\\.com/squne121/loop-protocol/(issues|pull)/[0-9]+#issuecomment-[0-9]+$",
          "maxLength": 300
        },
        "retro_index_payload_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "retro_index_source_set_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "chatgpt_marker_comment_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github\\.com/squne121/loop-protocol/(issues|pull)/[0-9]+#issuecomment-[0-9]+$",
          "maxLength": 300
        },
        "chatgpt_marker_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolver_command",
        "resolver_status",
        "checked_at",
        "checker_version",
        "public_safe",
        "semantic_checks"
      ],
      "properties": {
        "resolver_command": {
          "type": "string",
          "const": "pnpm chatgpt-retro-context:resolve-live"
        },
        "resolver_status": {
          "type": "string",
          "enum": [
            "resolved",
            "pending",
            "stale",
            "error"
          ]
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "checker_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "public_safe": {
          "type": "boolean",
          "const": true
        },
        "semantic_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          }
        },
        "operation_source_resolver": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "command",
            "status",
            "checked_at",
            "evidence_projection_digest",
            "target_commit",
            "pagination",
            "source_catalog"
          ],
          "properties": {
            "command": {
              "type": "string",
              "const": "pnpm chatgpt-retro-context:resolve-live"
            },
            "status": {
              "type": "string",
              "enum": [
                "resolved",
                "missing",
                "error"
              ]
            },
            "checked_at": {
              "type": "string",
              "format": "date-time"
            },
            "evidence_projection_digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            "target_commit": {
              "type": "string",
              "pattern": "^[0-9a-f]{40}$"
            },
            "pagination": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "reviews_complete",
                "review_comments_complete",
                "review_threads_complete",
                "thread_comments_complete"
              ],
              "properties": {
                "reviews_complete": {
                  "type": "boolean"
                },
                "review_comments_complete": {
                  "type": "boolean"
                },
                "review_threads_complete": {
                  "type": "boolean"
                },
                "thread_comments_complete": {
                  "type": "boolean"
                }
              }
            },
            "source_catalog": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "review_ids",
                "review_comment_ids",
                "review_thread_node_ids"
              ],
              "properties": {
                "review_ids": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "minimum": 1
                  }
                },
                "review_comment_ids": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "minimum": 1
                  }
                },
                "review_thread_node_ids": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^PRRT_[A-Za-z0-9_]+$",
                    "maxLength": 200
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "type": "object",
        "properties": {
          "operation": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "pr_review_submitted",
                  "pr_review_comment_created",
                  "pr_review_thread_resolved"
                ]
              }
            },
            "required": [
              "kind"
            ]
          }
        }
      },
      "then": {
        "type": "object",
        "properties": {
          "target": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "const": "pull_request"
              }
            }
          },
          "operation": {
            "type": "object",
            "properties": {
              "source": {}
            },
            "required": [
              "source"
            ]
          },
          "verification": {
            "type": "object",
            "properties": {
              "operation_source_resolver": {}
            },
            "required": [
              "operation_source_resolver"
            ]
          }
        }
      }
    }
  ]
}
