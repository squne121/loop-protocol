{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent_operation_session_index/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "repo",
    "parent_issue",
    "target",
    "operation",
    "agent_run",
    "public_artifacts",
    "verification"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "agent_operation_session_index/v1"
    },
    "repo": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
      "maxLength": 200
    },
    "parent_issue": {
      "type": "integer",
      "minimum": 1
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "number"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "issue",
            "pull_request"
          ]
        },
        "number": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "github_event_ref",
        "occurred_at"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "issue_comment",
            "issue_body_update",
            "issue_close",
            "pr_open",
            "pr_comment",
            "commit_push",
            "ci_retry",
            "merge"
          ]
        },
        "github_event_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "ref",
            "digest"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "github_issue",
                "github_pr",
                "github_comment",
                "workflow_run"
              ]
            },
            "ref": {
              "type": "string",
              "minLength": 1,
              "maxLength": 400
            },
            "digest": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          }
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "agent_run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "agent_surface",
        "evidence_mode",
        "capability_verdict",
        "raw_values_emitted"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "agent_surface": {
          "type": "string",
          "enum": [
            "claude_code",
            "codex_cli",
            "google_antigravity",
            "unknown"
          ]
        },
        "evidence_mode": {
          "type": "string",
          "enum": [
            "synthetic_route_proof",
            "synthetic_only",
            "real_pilot_verified"
          ]
        },
        "capability_verdict": {
          "type": "string",
          "enum": [
            "supported",
            "partial",
            "unsupported",
            "unverified"
          ]
        },
        "raw_values_emitted": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "public_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_report_comment_url",
        "run_report_payload_digest",
        "retro_index_comment_url",
        "retro_index_payload_digest",
        "retro_index_source_set_digest",
        "chatgpt_marker_comment_url",
        "chatgpt_marker_digest"
      ],
      "properties": {
        "run_report_comment_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github\\.com/squne121/loop-protocol/(issues|pull)/[0-9]+#issuecomment-[0-9]+$",
          "maxLength": 300
        },
        "run_report_payload_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "retro_index_comment_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github\\.com/squne121/loop-protocol/(issues|pull)/[0-9]+#issuecomment-[0-9]+$",
          "maxLength": 300
        },
        "retro_index_payload_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "retro_index_source_set_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "chatgpt_marker_comment_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github\\.com/squne121/loop-protocol/(issues|pull)/[0-9]+#issuecomment-[0-9]+$",
          "maxLength": 300
        },
        "chatgpt_marker_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolver_command",
        "resolver_status",
        "checked_at",
        "checker_version",
        "public_safe",
        "semantic_checks"
      ],
      "properties": {
        "resolver_command": {
          "type": "string",
          "const": "pnpm chatgpt-retro-context:resolve-live"
        },
        "resolver_status": {
          "type": "string",
          "enum": [
            "resolved",
            "pending",
            "stale",
            "error"
          ]
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "checker_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "public_safe": {
          "type": "boolean",
          "const": true
        },
        "semantic_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          }
        }
      }
    }
  }
}
