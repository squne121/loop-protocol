{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/squne121/loop-protocol/docs/schemas/agent-run-report.schema.json",
  "title": "agent_run_report/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "public_surface_kind",
    "public_safety",
    "actor",
    "authority",
    "token_usage",
    "manifest_refs",
    "evidence_refs",
    "commands_summary",
    "docs_read_refs"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "agent_run_report/v1"
    },
    "public_surface_kind": {
      "type": "string",
      "enum": [
        "github_issue_comment",
        "github_pr_comment",
        "none"
      ]
    },
    "public_safety": {
      "$ref": "#/$defs/publicSafety"
    },
    "actor": {
      "$ref": "#/$defs/actor"
    },
    "authority": {
      "$ref": "#/$defs/authority"
    },
    "token_usage": {
      "$ref": "#/$defs/tokenUsage"
    },
    "manifest_refs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/opaqueReference"
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/opaqueReference"
      }
    },
    "commands_summary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/commandSummary"
      }
    },
    "docs_read_refs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/docReadRef"
      }
    }
  },
  "$defs": {
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ai_agent",
            "github_action",
            "human"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "basis",
        "evidence_refs"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "authoritative",
            "derived",
            "non_authoritative"
          ]
        },
        "basis": {
          "type": "string",
          "enum": [
            "ai_self_report",
            "validated_manifest_ref",
            "github_action_check",
            "human_attestation"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/$defs/opaqueReference"
          }
        }
      }
    },
    "commandSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_label",
        "exit_code",
        "verdict",
        "summary",
        "artifact_ref"
      ],
      "properties": {
        "command_label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "exit_code": {
          "type": "integer",
          "minimum": 0
        },
        "verdict": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "skip"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 280
        },
        "artifact_ref": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "docReadRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_kind",
        "ref",
        "summary"
      ],
      "properties": {
        "ref_kind": {
          "type": "string",
          "enum": [
            "doc_path",
            "issue",
            "pull_request",
            "url"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        }
      }
    },
    "opaqueReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "validation_verdict"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "github_actions_artifact",
            "workflow_run",
            "schema_ref",
            "github_comment",
            "manifest_digest",
            "observation_projection_digest"
          ]
        },
        "artifact_id": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[0-9]{1,20}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "artifact_digest": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha256Digest"
            },
            {
              "type": "null"
            }
          ]
        },
        "workflow_run_url": {
          "oneOf": [
            {
              "type": "string",
              "format": "uri",
              "maxLength": 240
            },
            {
              "type": "null"
            }
          ]
        },
        "schema_ref": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 160
            },
            {
              "type": "null"
            }
          ]
        },
        "ref": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            },
            {
              "type": "null"
            }
          ]
        },
        "digest": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha256Digest"
            },
            {
              "type": "null"
            }
          ]
        },
        "validation_verdict": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "unknown"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "manifest_digest"
              }
            }
          },
          "then": {
            "properties": {
              "digest": {}
            },
            "required": [
              "digest"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "github_actions_artifact"
              }
            }
          },
          "then": {
            "properties": {
              "artifact_id": {},
              "artifact_digest": {},
              "workflow_run_url": {}
            },
            "required": [
              "artifact_id",
              "artifact_digest",
              "workflow_run_url"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "workflow_run"
              }
            }
          },
          "then": {
            "properties": {
              "ref": {},
              "digest": {}
            },
            "required": [
              "ref",
              "digest"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "github_comment"
              }
            }
          },
          "then": {
            "properties": {
              "ref": {},
              "digest": {}
            },
            "required": [
              "ref",
              "digest"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "schema_ref"
              }
            }
          },
          "then": {
            "properties": {
              "schema_ref": {}
            },
            "required": [
              "schema_ref"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "observation_projection_digest"
              }
            }
          },
          "then": {
            "properties": {
              "digest": {
                "$ref": "#/$defs/sha256Digest"
              },
              "validation_verdict": {
                "const": "pass"
              },
              "artifact_id": {
                "type": "null"
              },
              "artifact_digest": {
                "type": "null"
              },
              "workflow_run_url": {
                "type": "null"
              },
              "schema_ref": {
                "type": "null"
              },
              "ref": {
                "type": "null"
              }
            },
            "required": [
              "digest"
            ]
          }
        }
      ]
    },
    "observationMetricValue": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "observationSourceMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_count",
        "span_count",
        "prompt_tokens",
        "completion_tokens",
        "total_tokens"
      ],
      "properties": {
        "trace_count": {
          "$ref": "#/$defs/observationMetricValue"
        },
        "span_count": {
          "$ref": "#/$defs/observationMetricValue"
        },
        "prompt_tokens": {
          "$ref": "#/$defs/observationMetricValue"
        },
        "completion_tokens": {
          "$ref": "#/$defs/observationMetricValue"
        },
        "total_tokens": {
          "$ref": "#/$defs/observationMetricValue"
        }
      }
    },
    "observationSourceProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "ref",
        "source_projection_digest",
        "validator_id",
        "validator_policy_digest",
        "evidence_mode",
        "checked_at"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "observation_source_provenance/v1"
        },
        "ref": {
          "allOf": [
            {
              "$ref": "#/$defs/opaqueReference"
            },
            {
              "type": "object",
              "required": [
                "kind"
              ],
              "properties": {
                "kind": {
                  "const": "observation_projection_digest"
                }
              }
            }
          ]
        },
        "source_projection_digest": {
          "$ref": "#/$defs/sha256Digest"
        },
        "validator_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "validator_policy_digest": {
          "$ref": "#/$defs/sha256Digest"
        },
        "evidence_mode": {
          "type": "string",
          "enum": [
            "synthetic_only",
            "read_only_host_inventory",
            "real_pilot_verified"
          ]
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "observationSourceSafety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verdict",
        "raw_values_emitted",
        "forbidden_field_scan",
        "reason_codes"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "pass",
            "blocked"
          ]
        },
        "raw_values_emitted": {
          "const": false
        },
        "forbidden_field_scan": {
          "const": "pass"
        },
        "reason_codes": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/observationSourceReasonCode"
          }
        }
      }
    },
    "observationSourceReasonCode": {
      "type": "string",
      "maxLength": 80,
      "pattern": "^[a-z][a-z0-9_]{0,79}$",
      "enum": [
        "partial_projection",
        "synthetic_only_evidence",
        "host_inventory_only",
        "source_unavailable"
      ]
    },
    "observationSourceResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "source_kind",
        "capability_verdict",
        "availability",
        "projection_mode",
        "safety",
        "metrics",
        "provenance"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "observation_source_result/v1"
        },
        "source_kind": {
          "type": "string",
          "enum": [
            "claude_code",
            "codex_cli",
            "google_antigravity"
          ]
        },
        "capability_verdict": {
          "type": "string",
          "enum": [
            "supported",
            "partial",
            "unsupported",
            "unverified"
          ]
        },
        "availability": {
          "type": "string",
          "enum": [
            "available",
            "unavailable"
          ]
        },
        "projection_mode": {
          "type": "string",
          "enum": [
            "allowlist_projection",
            "not_projected"
          ]
        },
        "safety": {
          "$ref": "#/$defs/observationSourceSafety"
        },
        "metrics": {
          "$ref": "#/$defs/observationSourceMetrics"
        },
        "provenance": {
          "$ref": "#/$defs/observationSourceProvenance"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "capability_verdict": {
                "enum": [
                  "unsupported",
                  "unverified"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "availability": {
                "const": "unavailable"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "availability": {
                "const": "available"
              }
            }
          },
          "then": {
            "properties": {
              "capability_verdict": {
                "enum": [
                  "supported",
                  "partial"
                ]
              },
              "projection_mode": {
                "const": "allowlist_projection"
              },
              "safety": {
                "type": "object",
                "properties": {
                  "verdict": {
                    "const": "pass"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "availability": {
                "const": "available"
              }
            },
            "required": [
              "availability"
            ]
          },
          "then": {
            "properties": {
              "safety": {
                "type": "object",
                "properties": {
                  "reason_codes": {
                    "type": "array",
                    "not": {
                      "contains": {
                        "const": "source_unavailable"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "availability": {
                "const": "unavailable"
              }
            }
          },
          "then": {
            "properties": {
              "metrics": {
                "type": "object",
                "properties": {
                  "trace_count": {
                    "type": "null"
                  },
                  "span_count": {
                    "type": "null"
                  },
                  "prompt_tokens": {
                    "type": "null"
                  },
                  "completion_tokens": {
                    "type": "null"
                  },
                  "total_tokens": {
                    "type": "null"
                  }
                }
              },
              "safety": {
                "type": "object",
                "properties": {
                  "reason_codes": {
                    "type": "array",
                    "contains": {
                      "const": "source_unavailable"
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "capability_verdict": {
                "enum": [
                  "supported",
                  "unsupported",
                  "unverified"
                ]
              }
            },
            "required": [
              "capability_verdict"
            ]
          },
          "then": {
            "properties": {
              "safety": {
                "type": "object",
                "properties": {
                  "reason_codes": {
                    "type": "array",
                    "not": {
                      "contains": {
                        "const": "partial_projection"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "capability_verdict": {
                "const": "partial"
              },
              "availability": {
                "const": "available"
              }
            },
            "required": [
              "capability_verdict",
              "availability"
            ]
          },
          "then": {
            "properties": {
              "safety": {
                "type": "object",
                "properties": {
                  "reason_codes": {
                    "type": "array",
                    "contains": {
                      "const": "partial_projection"
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "publicSafety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redaction_status",
        "checked_by",
        "validator_version",
        "checked_at",
        "verdict",
        "blocked_reasons"
      ],
      "properties": {
        "redaction_status": {
          "type": "string",
          "enum": [
            "clean",
            "blocked"
          ]
        },
        "checked_by": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "validator_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "verdict": {
          "type": "string",
          "enum": [
            "pass",
            "fail"
          ]
        },
        "blocked_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          }
        },
        "observation_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/observationSourceResult"
          }
        },
        "entirecli_safety": {
          "$ref": "#/$defs/entirecliSafetyResult"
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "entirecli_safety"
            ],
          "properties": {
            "entirecli_safety": {
              "type": "object",
              "properties": {
                "verdict": {
                  "const": "safe"
                }
              }
              }
            }
          },
          "then": {
            "properties": {
              "entirecli_safety": {
                "type": "object",
                "properties": {
                  "reason_codes": {
                    "type": "array",
                    "maxItems": 0
                  },
                  "raw_values_emitted": {
                    "const": false
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "entirecli_safety"
            ],
          "properties": {
            "entirecli_safety": {
              "type": "object",
              "properties": {
                "verdict": {
                  "const": "not_applicable"
                }
              }
              }
            }
          },
          "then": {
            "properties": {
              "entirecli_safety": {
                "type": "object",
                "properties": {
                  "reason_codes": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 1,
                    "items": {
                      "const": "entire_absent"
                    },
                    "contains": {
                      "const": "entire_absent"
                    }
                  },
                  "raw_values_emitted": {
                    "const": false
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "entirecli_safety"
            ],
          "properties": {
            "entirecli_safety": {
              "type": "object",
              "properties": {
                "verdict": {
                  "const": "blocked"
                }
              }
              }
            }
          },
          "then": {
            "properties": {
              "entirecli_safety": {
                "type": "object",
                "properties": {
                  "reason_codes": {
                    "type": "array",
                    "minItems": 1
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "entirecli_safety"
            ],
          "properties": {
            "entirecli_safety": {
              "type": "object",
              "properties": {
                "raw_values_emitted": {
                  "const": true
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "entirecli_safety": {
                "type": "object",
                "properties": {
                  "verdict": {
                    "const": "blocked"
                  },
                  "reason_codes": {
                    "type": "array",
                    "contains": {
                      "const": "raw_value_redaction_violation"
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "entirecliCheckedSurfaces": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entire_binary",
        "entire_version",
        "entire_enable_help",
        "entire_configure_help"
      ],
      "properties": {
        "entire_binary": {
          "type": "boolean"
        },
        "entire_version": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            },
            {
              "type": "null"
            }
          ]
        },
        "entire_enable_help": {
          "type": "boolean"
        },
        "entire_configure_help": {
          "type": "boolean"
        }
      }
    },
    "entirecliSafetyResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "verdict",
        "reason_codes",
        "raw_values_emitted",
        "checked_surfaces"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "entirecli_safety_result/v1"
        },
        "verdict": {
          "type": "string",
          "enum": [
            "not_applicable",
            "safe",
            "blocked"
          ]
        },
        "reason_codes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "entire_absent",
              "public_checkpoint_branch_present",
              "push_sessions_enabled",
              "push_sessions_unknown",
              "checkpoint_remote_unknown_visibility",
              "checkpoint_remote_public",
              "checkpoint_token_without_private_remote",
              "public_push_remote_detected",
              "git_config_parse_error",
              "telemetry_enabled",
              "telemetry_unknown",
              "raw_value_redaction_violation",
              "settings_parse_error",
              "code_remote_unknown_visibility"
            ]
          }
        },
        "raw_values_emitted": {
          "type": "boolean"
        },
        "checked_surfaces": {
          "$ref": "#/$defs/entirecliCheckedSurfaces"
        }
      }
    },
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "tokenUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "availability",
        "source",
        "prompt",
        "completion",
        "total"
      ],
      "properties": {
        "availability": {
          "type": "string",
          "enum": [
            "available",
            "unavailable"
          ]
        },
        "source": {
