{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "chatgpt_retrospective_result/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "target",
    "input_marker_digest",
    "verdict",
    "findings",
    "follow_up_issue_candidates",
    "raw_values_emitted"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "chatgpt_retrospective_result/v1"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "type",
        "number"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "type": {
          "type": "string",
          "enum": [
            "issue",
            "pull_request"
          ]
        },
        "number": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "input_marker_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "approve",
        "request_changes",
        "blocked",
        "insufficient_evidence"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "title",
          "evidence_refs",
          "claim",
          "recommendation"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "blocker",
              "high",
              "medium",
              "low"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind",
                "ref",
                "digest"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "github_issue",
                    "github_pr",
                    "github_comment",
                    "repo_file",
                    "web_doc"
                  ]
                },
                "ref": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 400
                },
                "digest": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "pattern": "^sha256:[0-9a-f]{64}$"
                }
              }
            }
          },
          "claim": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "recommendation": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "follow_up_issue_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "body",
          "blocked_by",
          "public_safe"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "body": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4000
          },
          "blocked_by": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^#[0-9]+$"
            }
          },
          "public_safe": {
            "type": "boolean",
            "const": true
          }
        }
      }
    },
    "raw_values_emitted": {
      "type": "boolean",
      "const": false
    }
  }
}
