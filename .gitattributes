# Default: let Git classify text/binary, normalize text in the index.
* text=auto

# Scripts and source-like files that must remain LF on checkout.
*.sh      text eol=lf
*.bash    text eol=lf
*.zsh     text eol=lf
*.py      text eol=lf
*.js      text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.json    text eol=lf
*.jsonc   text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.md      text eol=lf
*.toml    text eol=lf
*.lock    text eol=lf

# Windows-specific files may use CRLF when such files appear later.
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf
*.sln     text eol=crlf

# Binary assets: never normalize or diff as text.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.ico     binary
*.mp3     binary
*.wav     binary
*.ogg     binary
*.mp4     binary
*.zip     binary
*.gz      binary
*.pdf     binary
*.ttf     binary
*.otf     binary
*.woff    binary
*.woff2   binary
